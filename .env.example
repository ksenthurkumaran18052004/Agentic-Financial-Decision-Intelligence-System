# ────────────────────────────────────────────────────────────────────────────
# LLM Configuration (Together AI — OpenAI-compatible)
# ────────────────────────────────────────────────────────────────────────────
TOGETHER_API_KEY=your_together_api_key_here

# ────────────────────────────────────────────────────────────────────────────
# Redis / Upstash Stream Configuration
# ────────────────────────────────────────────────────────────────────────────
# For Upstash REST API (recommended for serverless):
UPSTASH_REDIS_REST_URL=https://your-upstash-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# Optional: For direct Redis TCP/TLS (if you prefer)
# REDIS_URL=rediss://default:your_token@your-upstash-db.upstash.io:6379

# Redis Streams configuration
REDIS_STREAM_KEY=afdis:transactions
REDIS_STREAM_GROUP=afdis-consumers
REDIS_STREAM_CONSUMER=dashboard

# ────────────────────────────────────────────────────────────────────────────
# Agent Determinism & Behavior
# ────────────────────────────────────────────────────────────────────────────
AGENT_TEMPERATURE=0.2
AGENT_TOP_P=0.9
AGENT_MAX_RETRIES=2
AGENT_TIMEOUT_S=30.0

# ────────────────────────────────────────────────────────────────────────────
# ML Model Thresholds
# ────────────────────────────────────────────────────────────────────────────
RISK_THRESHOLD=0.6
FRAUD_THRESHOLD=-0.2

# ────────────────────────────────────────────────────────────────────────────
# MCTS Search Configuration
# ────────────────────────────────────────────────────────────────────────────
MCTS_SIMULATIONS=50
MCTS_EXPLORATION=1.41

# ────────────────────────────────────────────────────────────────────────────
# Data Generation (for testing / synthetic pipelines)
# ────────────────────────────────────────────────────────────────────────────
SYNTHETIC_SAMPLES=5000
FRAUD_RATE=0.08

# ────────────────────────────────────────────────────────────────────────────
# Optional: Observability & Monitoring
# ────────────────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# PROMETHEUS_PORT=8001
# DATADOG_API_KEY=your_datadog_api_key_here